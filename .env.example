# Generate a random API key for mcp-proxy authentication:
#   openssl rand -hex 32
MCP_API_KEY=your-random-api-key-here

# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret

# From the OAuth flow (see README for walkthrough)
STRAVA_ACCESS_TOKEN=your-access-token
STRAVA_REFRESH_TOKEN=your-refresh-token

# Optional: change the host port (default: 18201)
# STRAVA_MCP_PORT=18201
